# apps/api/.env.example
# Kopieren nach .env und Werte anpassen. Niemals die echte .env einchecken.

NODE_ENV=development
PORT=3000

# PostgreSQL-Verbindung (siehe docker-compose.yml für lokale Entwicklung)
DATABASE_URL="postgresql://lane1_app:lane1_dev_password@localhost:5432/lane1"

# Symmetrischer Signierschlüssel (Phase-0-Rest, aktuell v. a. als generischer
# Konfigurationswert genutzt) — mit `openssl rand -base64 48` erzeugen.
JWT_SIGNING_KEY="CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_48"

JWT_ACCESS_TTL="15m"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# RS256-Schlüsselpaar für Access Tokens (Abschnitt 5.2 des Backend-
# Entwicklungsplans). In development/test OPTIONAL — wird sonst automatisch
# ein Wegwerf-Schlüsselpaar pro Prozessstart erzeugt (siehe src/auth/keys.ts).
# In PRODUKTION PFLICHT. Erzeugen:
#
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out private.pem
#   openssl rsa -pubout -in private.pem -out public.pem
#
# Danach den Dateiinhalt hier einfügen, mit \n statt echten Zeilenumbrüchen:
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIj...\n-----END PUBLIC KEY-----"
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Origin des Frontends (apps/web) — für CORS
CORS_ORIGIN="http://localhost:5173"

# Basis-URL des Frontends — wird für den Einladungslink in der
# Versand-E-Mail gebraucht (Annahme-Seite: <FRONTEND_BASE_URL>/#/accept-invite/<token>).
FRONTEND_BASE_URL="http://localhost:5173"

# SMTP-Konfiguration für den Einladungs-E-Mail-Versand (Superadmin-
# Oberfläche "/admin"). Bleibt SMTP_HOST leer, wird die Einladung nur ins
# Server-Log geschrieben statt versendet (praktisch für lokale
# Entwicklung/Demo ohne eigenen Mailserver).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL="noreply@mein-verein.de"
SMTP_FROM_NAME="Lane 1"

# DSGVO (Art. 17): Tage zwischen einer Löschanfrage (sofortiger Soft-Delete)
# und dem endgültigen, unwiderruflichen Hard-Purge durch
# `npm run purge-deleted-data` (siehe README, Abschnitt "DSGVO: Auskunft & Löschung").
DATA_ERASURE_RETENTION_DAYS=30
