{
  "name": "@lane1/api",
  "private": true,
  "version": "0.2.0",
  "description": "Lane 1 — Node.js-Backend (Fastify). Phase 2: vollständiges fachliches Datenmodell (athletes, competitions, plans, …) inkl. Seed-Skript. Phase 1: einladungsbasierte Authentifizierung (JWT/RS256, argon2id), Vereins-/Einladungsverwaltung.",
  "type": "module",
  "main": "dist/index.js",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "create-superadmin": "tsx scripts/createSuperAdmin.ts"
  },
  "dependencies": {
    "@lane1/shared-types": "*",
    "@lane1/sync-protocol": "*",
    "@prisma/client": "^5.20.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "hash-wasm": "^4.11.0",
    "jose": "^5.9.6",
    "nodemailer": "^6.9.15",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/nodemailer": "^6.4.16",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
